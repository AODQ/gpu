#version 460
#extension GL_EXT_buffer_reference : require
#extension GL_EXT_scalar_block_layout : require
#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_nonuniform_qualifier : require
#extension GL_EXT_shader_image_load_formatted : require

layout(set = 0, binding = 5) uniform image3D vkofImages3D[];

layout(push_constant, scalar) uniform PC {
	layout(offset = 128) uint imgHandle;
	uint countX;
	uint countY;
	uint countZ;
} pc;

// workgroup = one probe tile; dispatch (countX, countY, countZ)
layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

void main() {
	uint px = gl_WorkGroupID.x;
	uint py = gl_WorkGroupID.y;
	uint pz = gl_WorkGroupID.z;
	uint lx = gl_LocalInvocationID.x;
	uint ly = gl_LocalInvocationID.y;
	// encode (pz, px, py) so all three axes produce distinct values
	float val = float(pz) * 1000.0 + float(px) * 10.0 + float(py);
	imageStore(
		vkofImages3D[nonuniformEXT(pc.imgHandle)],
		ivec3(int(px) * 8 + int(lx), int(py) * 8 + int(ly), int(pz)),
		vec4(val, 0.0, 0.0, 1.0)
	);
}
