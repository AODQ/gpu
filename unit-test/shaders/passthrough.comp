#version 460
#extension GL_EXT_buffer_reference2 : require
#extension GL_EXT_shader_explicit_arithmetic_types_int64 : require

// BDA pointer to a u32 array
layout(buffer_reference, buffer_reference_align = 4) buffer UintBuffer {
    uint data[];
};

// Per-dispatch push constants start at byte 128 (root constants occupy [0,128))
layout(push_constant) uniform PushConstants {
    layout(offset = 128) uint64_t srcBDA;
    uint64_t dstBDA;
    uint count;
    uint _pad;
} pc;

layout(local_size_x = 64) in;

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= pc.count) { return; }
    UintBuffer(pc.dstBDA).data[idx] = UintBuffer(pc.srcBDA).data[idx];
}
