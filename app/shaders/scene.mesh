#version 450
#extension GL_EXT_mesh_shader                      : require
#extension GL_EXT_buffer_reference                 : require
#extension GL_EXT_scalar_block_layout              : require
#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_GOOGLE_include_directive             : require

#include "scene_shared.h"

layout(local_size_x = 64) in;
layout(triangles, max_vertices = 64, max_primitives = 124) out;

layout(location = 0) flat out uint outVisibility[];

void main() {
	MeshletBuf meshletBuf = MeshletBuf(pc.draw.meshlets);
	const Meshlet m = meshletBuf.data[gl_WorkGroupID.x];
	InstanceBuf instanceBuf = InstanceBuf(pc.draw.instances);
	const mat4 transform = (
		pc.draw.modelMatrix * instanceBuf.data[m.instanceIndex].transform
	);

	PositionBuf posBuf  = PositionBuf(pc.draw.positions);
	MeshletVertBuf vertBuf = MeshletVertBuf(pc.draw.meshletVerts);
	MeshletTriBuf triBuf  = MeshletTriBuf(pc.draw.meshletTris);

	SetMeshOutputsEXT(m.vertexCount, m.triangleCount);

	const uint i = gl_LocalInvocationID.x;

	if (i < m.vertexCount) {
		const uint globalIdx = vertBuf.data[m.vertexOffset + i];
		const vec4 worldPos  = transform * vec4(posBuf.data[globalIdx], 1.0);
		gl_MeshVerticesEXT[i].gl_Position = pc.global.viewProj * worldPos;

		const uint modelId = pc.draw.modelId;
		const uint meshLocalId = gl_WorkGroupID.x;
		// visibility mask is: modelId 8b, meshLocalId 17b, triangleId 7b
		// fragment shader will fill the rest with gl_PrimitiveID
		outVisibility[i] = (modelId << 24) | ((meshLocalId + 1u) << 7);
	}

	if (i < m.triangleCount) {
		const uint base = m.triangleOffset + i * 3;
		gl_PrimitiveTriangleIndicesEXT[i] = uvec3(
			uint(triBuf.data[base + 0]),
			uint(triBuf.data[base + 1]),
			uint(triBuf.data[base + 2])
		);
		gl_MeshPrimitivesEXT[i].gl_PrimitiveID = int(i);
	}

	// meshlets can have up to 124 triangles but only 64 invocations;
	// each invocation handles a second triangle if needed
	const uint j = i + 64u;
	if (j < m.triangleCount) {
		const uint base = m.triangleOffset + j * 3;
		gl_PrimitiveTriangleIndicesEXT[j] = uvec3(
			uint(triBuf.data[base + 0]),
			uint(triBuf.data[base + 1]),
			uint(triBuf.data[base + 2])
		);
		gl_MeshPrimitivesEXT[j].gl_PrimitiveID = int(j);
	}
}
