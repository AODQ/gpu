// irradiance trace; 8x8 rays per probe into an 8x8 texel octahedron map

layout(local_size_x = 8, local_size_y = 8) in;

layout(set = 0, binding = 5) uniform image3D vkofImages3D[];
layout(set = 0, binding = 4) uniform sampler3D vkofTextures3D[];
layout(set = 0, binding = 3) uniform accelerationStructureEXT vkofTlas;

#include "shared/ddgi-shared.h"
