shared struct {
	vec3 dir;
	vec3 irradiance;
	float dist;
} sharedRays[8*8];

void traceRay(const vec3 rayDir) {
	const GpuDebugPC dbg = GpuDebugPCBuffer(pc.global.debug).data;
	const vec3 origin = rayOrigin();
	sharedRays[gl_LocalInvocationIndex].dir = rayDir;
	sharedRays[gl_LocalInvocationIndex].irradiance = vec3(0.0);
	sharedRays[gl_LocalInvocationIndex].dist = 0.0;

	rayQueryEXT rq;
	rayQueryInitializeEXT(
		rq,
		vkofTlas,
		gl_RayFlagsOpaqueEXT,
		0xFF,
		origin,
		0.001f,
		rayDir,
		1000.0f
	);
	rayQueryProceedEXT(rq);

	const bool hit = (
		rayQueryGetIntersectionTypeEXT(rq, true)
		!= gl_RayQueryCommittedIntersectionNoneEXT
	);
	if (!hit) {
		sharedRays[gl_LocalInvocationIndex].irradiance = (
			sampleSky(rayDir, dbg.sunDir, dbg.skyTurbidity, dbg.skyIntensity)
		);
		return;
	}

	const float hitDist = rayQueryGetIntersectionTEXT(rq, true);
	sharedRays[gl_LocalInvocationIndex].dist = hitDist;
	const vec3 hitPos = origin + rayDir * hitDist;

	GpuLightBuffer lightBuf = GpuLightBuffer(pc.global.lightsVa);
	vec3 irradiance = vec3(0.0);
	for (uint i = 0u; i < pc.global.lightCount; ++i) {
		const GpuLight light = lightBuf.data[i];
		const vec3 toLight = light.position - hitPos;
		const float lightDist = length(toLight);
		const vec3 wo = toLight / lightDist;
		rayQueryEXT shadowRq;
		rayQueryInitializeEXT(
			shadowRq,
			vkofTlas,
			gl_RayFlagsTerminateOnFirstHitEXT | gl_RayFlagsOpaqueEXT,
			0xFF,
			hitPos,
			0.001f,
			wo,
			lightDist - 0.001f
		);
		rayQueryProceedEXT(shadowRq);
		const bool inShadow = (
			rayQueryGetIntersectionTypeEXT(shadowRq, true)
			!= gl_RayQueryCommittedIntersectionNoneEXT
		);
		if (inShadow) { continue; }
		const float distNorm = lightDist / light.radius;
		const float falloff = (
			clamp(1.0 - distNorm*distNorm*distNorm*distNorm, 0.0, 1.0)
		);
		const float atten = (
			(falloff * falloff) / (lightDist * lightDist + 1.0)
		);
		irradiance += light.color * atten;
	}

	// -- second bounce: look up geometry at hit, sample DDGI irradiance there
	if (pc.global.ddgiGrid != 0u && pc.global.models != 0u) {
