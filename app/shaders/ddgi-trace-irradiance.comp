		// );
		// const uint i2 = (
		// 	GpuFlatIndexBuffer(desc.flatIndices).data[primIdx * 3u + 2u]
		// );

		// const vec3 n0 = (
		// 	GpuMorVertexAttributeBuffer(desc.attributes).data[i0].normal
		// );
		// const vec3 n1 = (
		// 	GpuMorVertexAttributeBuffer(desc.attributes).data[i1].normal
		// );
		// const vec3 n2 = (
		// 	GpuMorVertexAttributeBuffer(desc.attributes).data[i2].normal
		// );

		// const vec3 localNormal = normalize(
		// 	n0 * (1.0 - bary.x - bary.y) + n1 * bary.x + n2 * bary.y
		// );
		// const mat3 normalMat = transpose(inverse(mat3(desc.modelMatrix)));
		// const vec3 worldNormal = normalize(normalMat * localNormal);

		// const uint hitMi = GpuFlatMeshletBuffer(desc.flatMeshlets).data[primIdx];
		// const GpuMorMeshlet hitMeshlet = (
		// 	GpuMorMeshletBuffer(desc.meshlets).data[hitMi]
		// );
		// const GpuMorMaterial hitMat = (
		// 	GpuMorMaterialBuffer(desc.materials).data[hitMeshlet.materialIndex]
		// );

		// // -- sun contribution at bounce hit
		// if (dbg.sunIntensity > 0.0) {
		// 	const float dotNL = max(dot(worldNormal, dbg.sunDir), 0.0);
		// 	if (dotNL > 0.0 && dbg.sunDir.y > 0.0) {
		// 		rayQueryEXT sunRq;
		// 		rayQueryInitializeEXT(
		// 			sunRq,
		// 			vkofTlas,
		// 			gl_RayFlagsTerminateOnFirstHitEXT | gl_RayFlagsOpaqueEXT,
		// 			0xFFu,
		// 			hitPos + worldNormal * 0.001f,
		// 			0.001f,
		// 			dbg.sunDir,
		// 			10000.0f
		// 		);
		// 		rayQueryProceedEXT(sunRq);
		// 		const bool sunOccluded = (
		// 			rayQueryGetIntersectionTypeEXT(sunRq, true)
		// 			!= gl_RayQueryCommittedIntersectionNoneEXT
		// 		);
		// 		if (!sunOccluded) {
		// 			const vec3 sunColor = sunLightColor(dbg.sunDir, dbg.skyTurbidity);
		// 			irradiance += (
		// 				hitMat.baseColor.rgb * sunColor * dotNL * dbg.sunIntensity
		// 			);
		// 		}
		// 	}
		// }

		// irradiance += hitMat.emissive;
		// irradiance += hitMat.baseColor.rgb * sampleProbeIrradiance(hitPos, worldNormal);
	}

	sharedRays[gl_LocalInvocationIndex].irradiance = irradiance;
}

void main() {
	// -- trace rays
	traceRay(rayDirection());

	// -- synchronize shared mem
	barrier();

	// -- get the local offset into probe and the global offset into the grid
	const uint probeOffI = gl_LocalInvocationID.x;
	const uint probeOffJ = gl_LocalInvocationID.y;

	const uint px = gl_WorkGroupID.x;
	const uint py = gl_WorkGroupID.y % pc.ddgi.probeCounts.y;
	const uint pz = gl_WorkGroupID.y / pc.ddgi.probeCounts.y;

	// -- toroidal atlas slot and history validity for this probe
	const uvec3 atlasSlot = ddgiAtlasSlot(uvec3(px, py, pz));
	const float blendWeight = ddgiIsNewProbe(atlasSlot) ? 1.0f : 0.1f;

	// -- get texel direction from octahedron encoding
	const vec2 texelCoord = (
		(
			(vec2(probeOffI, probeOffJ) + vec2(0.5f))
			/ vec2(8.0f, 8.0f) * vec2(2.0f)
		)
		- vec2(1.0f)
	);
	const vec3 texelDir = octahedronDecode(texelCoord);

	// -- combine results from all rays
	float weightedSum = 0.0f;
	vec3 weightedIrradiance = vec3(0.0f);
	for (uint k = 0u; k < 8u*8u; ++k) {
		const float weight = max(0.0f, dot(texelDir, sharedRays[k].dir));
		weightedSum += weight;
		weightedIrradiance += weight * sharedRays[k].irradiance;
	}

	// -- combine with previous irradiance history
	const ivec3 probeGridCoord = ivec3(
		int(atlasSlot.x) * 8 + int(probeOffI),
		int(atlasSlot.y) * 8 + int(probeOffJ),
		int(atlasSlot.z)
	);
	const vec3 previousIrradiance = (
		imageLoad(
			vkofImages3D[nonuniformEXT(pc.ddgi.irradianceStorageHandle)],
			probeGridCoord
		).rgb
	);
	const vec3 newIrradiance = weightedIrradiance / max(1.0f, weightedSum);
	const vec3 combinedIrradiance = (
		mix(previousIrradiance, newIrradiance, blendWeight)
	);
	imageStore(
		vkofImages3D[nonuniformEXT(pc.ddgi.irradianceStorageHandle)],
		probeGridCoord,
		vec4(combinedIrradiance, 1.0f)
	);
}
